# Copy this file to .env.local and fill in real values from your Supabase project
# (Project Settings -> API), Google Cloud OAuth client, and Cloudflare R2.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Domain allowed to sign in and view the site.
NEXT_PUBLIC_ALLOWED_EMAIL_DOMAIN=vitrox.com

# Cloudflare R2 (private bucket) - image storage. Never prefix these with
# NEXT_PUBLIC_, they're server-only credentials.
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=vip-violation-images
